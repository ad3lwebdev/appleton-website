@tailwind base;
@tailwind components;
@tailwind utilities;

html {
  scroll-behavior: smooth;
}

body {
  @apply bg-foam text-basalt font-body antialiased;
}

::selection {
  @apply bg-brass/30 text-basalt;
}

.wrap {
  @apply mx-auto max-w-wrap px-6 md:px-10;
}

.eyebrow {
  @apply font-mono text-[11px] tracking-[0.18em] uppercase text-brass-dark;
}

.eyebrow-light {
  @apply font-mono text-[11px] tracking-[0.18em] uppercase text-brass-light;
}

.btn {
  @apply inline-flex items-center gap-2.5 rounded-sm px-7 py-4 text-[14px] font-semibold transition-all duration-200;
}
.btn-primary {
  @apply bg-brass text-estuary-dark hover:bg-brass-dark hover:text-foam hover:-translate-y-0.5;
}
.btn-ghost {
  @apply border border-foam/50 text-foam hover:bg-foam/10 hover:border-foam hover:-translate-y-0.5;
}
.btn-outline {
  @apply border border-estuary text-estuary hover:bg-estuary hover:text-foam hover:-translate-y-0.5;
}

.field-input {
  @apply rounded-sm border border-basalt/15 bg-white px-3.5 py-3 text-[14.5px] text-basalt outline-none transition-colors focus:border-tide;
}

.grain::after {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
  background-image: theme("backgroundImage.grain");
  mix-blend-mode: overlay;
}

@media (prefers-reduced-motion: reduce) {
  *, *::before, *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}
